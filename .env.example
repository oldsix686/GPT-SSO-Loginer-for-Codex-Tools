GPT_SSO_EMAIL=
EMAILS_FILE=emails.txt
TARGET=codex-tools

# codex-tools mode: empty means %APPDATA%\com.carry.codex-tools on Windows.
CODEX_TOOLS_DATA_DIR=

# cpa mode only.
CPA_URL=http://127.0.0.1:1455
CPA_MANAGEMENT_KEY=replace-me

# Optional. Leave OAUTH_URL empty unless you know exactly what you are doing.
OAUTH_URL=

# IDP-first SSO mode.
IDP_SSO_MODE=off
IDP_BASE=https://idp.example.com
IDP_TOKEN=
IDP_CLIENT_ID=
IDP_ACCOUNT_ID=
IDP_START_URL=
IDP_START_URL_TEMPLATE=
IDP_TIMEOUT_MS=30000
IDP_PRIME_TIMEOUT_MS=15000
IDP_ME_PAGE_SIZE=50

# Leave these empty to use built-in UTF-8-safe defaults.
WORKSPACE_LABEL=
CASDOOR_LOGIN_LABEL=
DOG_AVATAR_SELECTOR=a.provider-link[href*="/oauth/authorize"]

BROWSER_MODE=cdp
BROWSER_CDP_URL=http://127.0.0.1:9222
REMOTE_DEBUGGING_PORT=9222
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_USER_DATA_DIR=
CHROME_DEBUG_USER_DATA_DIR=profiles/real-chrome-cdp
CHROME_PROFILE_DIRECTORY=Default

BROWSER_HEADLESS=false
BROWSER_SLOW_MO_MS=120
PROFILE_DIR=profiles/chrome-shared
ARTIFACTS_DIR=artifacts
USED_EMAILS_FILE=used-emails.txt
USED_EMAILS_AUDIT_FILE=
SKIP_USED_EMAILS=true
TRACK_USED_EMAILS=true
MAX_RETRIES=3
BATCH_DELAY_MS=2500
STRICT_EMAIL_MATCH=true

SHARED_BROWSER_PROFILE=true
FRESH_PROFILE=false
CLEAR_AUTH_STATE=false
CLEAR_OAUTH_ORIGIN=false
FORCE_OPENAI_LOGIN=true
RESET_OPENAI_SESSION_BEFORE_LOGIN=false
STEALTH_LAUNCH_ARGS=false
REQUIRE_LOGIN_INTERACTION=true
STOP_ON_FAILURE=true

PAUSE_FOR_PLATFORM_LOGIN=true
PLATFORM_LOGIN_TIMEOUT_MS=600000
PAUSE_FOR_CLOUDFLARE=true
CLOUDFLARE_TIMEOUT_MS=600000
SYNC_PLATFORM_EMAILS_BEFORE_LOGIN=true
